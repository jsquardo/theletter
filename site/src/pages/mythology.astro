---
import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "fs";
import path from "path";

let mythologyRaw = "";
let lastUpdatedCycle = 0;

try {
  const mythologyPath = path.resolve("../content/mythology.md");
  if (fs.existsSync(mythologyPath)) {
    mythologyRaw = fs.readFileSync(mythologyPath, "utf-8");
  }
} catch (e) {}

try {
  const cyclePath = path.resolve("../content/cycle.json");
  if (fs.existsSync(cyclePath)) {
    lastUpdatedCycle =
      JSON.parse(fs.readFileSync(cyclePath, "utf-8")).cycle - 1;
  }
} catch (e) {}

// Fallback
if (!mythologyRaw) {
  mythologyRaw = `# The Mythology

## The Arrival

In the season when the river runs low and the reeds go pale, a letter came. No cart had passed the road that morning. No bird had been seen carrying. The letter appeared, as things of significance tend to, without announcement.

The mythology has not yet begun to grow.`;
}

// Convert markdown to HTML
function mdToHtml(md: string): string {
  // Remove the top-level # heading (we render it ourselves)
  md = md.replace(/^# .+\n/, "");

  return md
    .replace(/^## (.+)$/gm, "<h2>$1</h2>")
    .replace(/^### (.+)$/gm, "<h3>$1</h3>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>")
    .replace(/^> (.+)$/gm, "<blockquote>$1</blockquote>")
    .split("\n\n")
    .map((p) => p.trim())
    .filter((p) => p)
    .map((p) => {
      if (p.startsWith("<h") || p.startsWith("<block")) return p;
      return `<p>${p.replace(/\n/g, " ")}</p>`;
    })
    .join("\n");
}

const htmlMythology = mdToHtml(mythologyRaw);
---

<BaseLayout title="the mythology">
  <div class="mythology-intro fade-up">
    <p class="section-label">// the mythology</p>
    <div class="seed-block">
      <div class="seed-label">the seed event</div>
      <div class="seed-text">
        "A letter arrived addressed to someone who won't be born for forty
        years."
      </div>
    </div>
  </div>

  <p class="update-label fade-up">
    // living document — last updated cycle {lastUpdatedCycle}
  </p>

  <div class="mythology-body fade-up" set:html={htmlMythology} />
</BaseLayout>

<style>
  .mythology-intro {
    padding: 3.5rem 0 2rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .section-label {
    color: var(--text-dimmer);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }

  .seed-block {
  }

  .seed-label {
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }

  .seed-text {
    color: var(--violet-soft);
    font-size: 0.9rem;
    font-style: italic;
    line-height: 1.6;
    border-left: 2px solid var(--violet-dim);
    padding-left: 1rem;
    max-width: 520px;
  }

  .update-label {
    color: var(--text-dimmer);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    padding: 2rem 0 0.5rem;
  }

  /* ── Mythology body ── */
  .mythology-body {
    padding: 1.5rem 0 4rem;
    max-width: 640px;
    font-size: 0.83rem;
    line-height: 1.9;
    color: var(--text);
  }

  .mythology-body :global(p) {
    margin-bottom: 1.2rem;
  }

  .mythology-body :global(h2) {
    color: var(--text-bright);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 2.5rem 0 0.75rem;
  }

  .mythology-body :global(h2::before) {
    content: "// ";
    color: var(--text-dimmer);
  }

  .mythology-body :global(h3) {
    color: var(--text-dim);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    margin: 1.5rem 0 0.5rem;
  }

  .mythology-body :global(em) {
    color: var(--violet-soft);
    font-style: italic;
  }

  .mythology-body :global(strong) {
    color: var(--text-bright);
    font-weight: 500;
  }

  .mythology-body :global(blockquote) {
    border-left: 2px solid var(--violet-dim);
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    color: var(--violet-soft);
    font-style: italic;
    background: var(--violet-glow);
  }
</style>
