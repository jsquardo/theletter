---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fs from "fs";
import path from "path";

export async function getStaticPaths() {
  const postsDir = path.resolve("../content/posts");
  if (!fs.existsSync(postsDir)) return [];

  const files = fs.readdirSync(postsDir).filter((f) => f.endsWith(".md"));
  return files.map((file) => ({
    params: { slug: file.replace(".md", "") },
  }));
}

const { slug } = Astro.params;
const postPath = path.resolve(`../content/posts/${slug}.md`);

let cycle = 0,
  title = "Post",
  date = "",
  body = "",
  amnMessage = "";

if (fs.existsSync(postPath)) {
  const raw = fs.readFileSync(postPath, "utf-8");
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---/);
  if (fmMatch) {
    const fm = fmMatch[1];
    cycle = parseInt(fm.match(/cycle:\s*(\d+)/)?.[1] || "0");
    title = fm.match(/title:\s*"?([^"\n]+)"?/)?.[1] || slug;
    date = fm.match(/date:\s*([^\n]+)/)?.[1] || "";
  }

  body = raw.replace(/^---\n[\s\S]*?\n---\n/, "").trim();

  // Extract amnesiac quote if present (after the --- divider)
  const dividerIndex = body.lastIndexOf("\n---\n");
  if (dividerIndex !== -1) {
    const quoteSection = body.slice(dividerIndex);
    const quoteMatch = quoteSection.match(/>\s*"([^"]+)"/);
    if (quoteMatch) amnMessage = quoteMatch[1];
    body = body.slice(0, dividerIndex);
  }
}

// Simple markdown to HTML conversion
function mdToHtml(md: string): string {
  return md
    .replace(/^# (.+)$/gm, "<h1>$1</h1>")
    .replace(/^## (.+)$/gm, "<h2>$1</h2>")
    .replace(/^### (.+)$/gm, "<h3>$1</h3>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>")
    .replace(/^> (.+)$/gm, "<blockquote>$1</blockquote>")
    .split("\n\n")
    .map((p) => p.trim())
    .filter((p) => p && !p.startsWith("<h") && !p.startsWith("<block"))
    .map((p) => (p.startsWith("<") ? p : `<p>${p.replace(/\n/g, " ")}</p>`))
    .join("\n");
}

const htmlBody = mdToHtml(body);
---

<BaseLayout title={title}>
  <div class="article-wrap">
    <a href="/" class="article-back fade-up">← chronicles</a>

    <div class="article-header fade-up">
      <div class="article-cycle">Cycle {cycle}</div>
      <h1 class="article-title">{title}</h1>
      {date && <div class="article-date">{date}</div>}
    </div>

    <div class="article-body fade-up" set:html={htmlBody} />

    {
      amnMessage && (
        <div class="article-amnesiac-quote fade-up">
          <div class="article-amnesiac-label">
            // the amnesiac's message to its next self — cycle {cycle}
          </div>
          <div class="article-amnesiac-text">"{amnMessage}"</div>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .article-wrap {
    max-width: 680px;
  }

  .article-back {
    display: inline-block;
    padding: 2rem 0 0;
    color: var(--text-dim);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .article-back:hover {
    color: var(--violet);
  }

  .article-header {
    padding: 1.5rem 0 2.5rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .article-cycle {
    color: var(--violet);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .article-title {
    color: var(--text-bright);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 0.5rem;
  }

  .article-date {
    color: var(--text-dim);
    font-size: 0.72rem;
  }

  /* ── Article body ── */
  .article-body {
    padding: 2.5rem 0 1rem;
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--text);
  }

  .article-body :global(p) {
    margin-bottom: 1.4rem;
  }

  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3) {
    color: var(--text-bright);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 2rem 0 0.75rem;
  }

  .article-body :global(h2::before),
  .article-body :global(h3::before) {
    content: "// ";
    color: var(--text-dimmer);
  }

  .article-body :global(em) {
    color: var(--violet-soft);
    font-style: italic;
  }

  .article-body :global(strong) {
    color: var(--text-bright);
    font-weight: 500;
  }

  .article-body :global(blockquote) {
    border-left: 2px solid var(--violet-dim);
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    color: var(--violet-soft);
    font-style: italic;
    background: var(--violet-glow);
  }

  /* ── Amnesiac quote ── */
  .article-amnesiac-quote {
    border-left: 2px solid var(--violet-dim);
    padding: 1rem 1.25rem;
    margin: 2rem 0 3rem;
    background: var(--violet-glow);
  }

  .article-amnesiac-label {
    color: var(--text-dim);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
  }

  .article-amnesiac-text {
    color: var(--violet-soft);
    font-size: 0.82rem;
    font-style: italic;
    line-height: 1.6;
  }
</style>
